# OmniSync — copy to .env.local (dev) or set in Cloudflare / Railway dashboards.
# Never commit real secrets.

# --- App URLs ---
# Public URL used in email CTAs (never localhost). Falls back to production Worker URL.
EMAIL_APP_URL=https://omnisync.mamutech-online.workers.dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# --- InsForge ---
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=
INSFORGE_API_KEY=

# --- AI ---
GEMINI_API_KEY=

# --- Google / Gmail OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Slack OAuth ---
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# --- Microsoft / Outlook OAuth ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Discord OAuth + bot ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# --- LinkedIn OAuth ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Calendly OAuth ---
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=

# --- Trigger.dev (use tr_prod_... in production) ---
TRIGGER_SECRET_KEY=

# --- Web Push (npm run generate:vapid) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@omnisync.local

# --- Resend (email alerts + briefing digests) ---
RESEND_API_KEY=
# Verified sender — either bare email or "Loopin <alerts@yourdomain.com>"
RESEND_FROM=
RESEND_FROM_EMAIL=

# --- Admin allowlist ---
ADMIN_EMAILS=
NEXT_PUBLIC_ADMIN_EMAILS=

# --- WhatsApp always-on worker (Railway / Render / Fly) ---
# Leave empty for local Baileys inside Next.js (npm run dev).
WHATSAPP_WORKER_URL=
WHATSAPP_WORKER_SECRET=

# Optional
CRON_SECRET=
SENT_DM_API_KEY=
SENT_DM_TEMPLATE_ID=
